		gsap.registerPlugin(SplitText);

		document.fonts.ready.then(() => {
			var tl = gsap.timeline({
				/*	onComplete: runPopUp,*/
					defaults: { ease: "power1.out" }
				}), 
				mySplitText = new SplitText(".tagline", {type:"chars,words", wordsClass:"word++",mask:"lines"}), 
				words = mySplitText.words;

			tl.from(words, {opacity:0, scale:0, y:100, ease:"back.out", stagger: 0.2})
				.to('.word3', {scale: 1.3, transformOrigin:"50% 75%", color:'#FF0000', padding:'0 1rem'}, '+=0')
				.to('.word3', {scale: 1, color:'#fff', padding:'0'}, '+=0')
				.from(".events-button", {delay: 1, duration: 1, y: 100, ease: "bounce", autoAlpha: 0}, '+=0')   
				.addPause(">2")
		});
/*		
		function runPopUp() {
		  if (!modalShown) {
				modal.show();
					Cookies.set('new-years-eve-2026-pop-up', 'yes', { expires: 1 })
			}
		}
*/
		});

	</script>


